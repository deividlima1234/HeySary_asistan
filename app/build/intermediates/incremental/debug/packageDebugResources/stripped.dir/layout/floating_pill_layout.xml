<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_dim">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Avatar y Engranajes (Animados) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/avatar_stack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp">

            <!-- Engranaje Exterior -->
            <ImageView
                android:id="@+id/outer_gear"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:src="@drawable/jarvis_gear"
                android:alpha="0.4"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Engranaje Interior -->
            <ImageView
                android:id="@+id/inner_gear"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/jarvis_gear"
                android:alpha="0.3"
                android:rotation="45"
                app:layout_constraintBottom_toBottomOf="@+id/outer_gear"
                app:layout_constraintEnd_toEndOf="@+id/outer_gear"
                app:layout_constraintStart_toStartOf="@+id/outer_gear"
                app:layout_constraintTop_toTopOf="@+id/outer_gear" />

            <!-- Resplandor Reactivo (Ondas) -->
            <View
                android:id="@+id/core_glow"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="@drawable/avatar_glow_bg"
                android:alpha="0.6"
                app:layout_constraintBottom_toBottomOf="@+id/outer_gear"
                app:layout_constraintEnd_toEndOf="@+id/outer_gear"
                app:layout_constraintStart_toStartOf="@+id/outer_gear"
                app:layout_constraintTop_toTopOf="@+id/outer_gear" />

            <!-- Núcleo Jarvis -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/jarvis_core"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:padding="3dp"
                android:scaleType="centerCrop"
                android:src="@drawable/dashboard_avatar"
                android:background="@drawable/avatar_glow_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cyberpunk_red"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:layout_constraintBottom_toBottomOf="@+id/outer_gear"
                app:layout_constraintEnd_toEndOf="@+id/outer_gear"
                app:layout_constraintStart_toStartOf="@+id/outer_gear"
                app:layout_constraintTop_toTopOf="@+id/outer_gear" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Caja de Respuesta Estilo HUD Jarvis -->
        <FrameLayout
            android:id="@+id/response_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:background="@drawable/hud_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header Tecnológico -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <View
                            android:layout_width="4dp"
                            android:layout_height="12dp"
                            android:background="@color/cyberpunk_red"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SARY INTELLIGENCE // HUD.v2"
                            android:textColor="@color/cyberpunk_red"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:fontFamily="serif-monospace"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/close_response"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_alignParentEnd="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:alpha="0.7"
                        android:padding="4dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/cyberpunk_red" />
                </RelativeLayout>

                <!-- Divisor Decorativo -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.3"
                    android:background="@color/cyberpunk_red"
                    android:layout_marginHorizontal="16dp" />

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="300dp"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/response_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="6dp"
                            android:text="Iniciando protocolos..."
                            android:textColor="@color/white"
                            android:fontFamily="serif-monospace"
                            android:textSize="15sp" />

                        <FrameLayout
                            android:id="@+id/dynamic_content_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp" />
                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>

                <!-- Footer Decorativo (Bits de datos) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:padding="8dp"
                    android:alpha="0.4"
                    android:text="STATUS: ACTIVE | ENCRYPTED: AES-256"
                    android:textColor="@color/white"
                    android:textSize="8sp"
                    android:fontFamily="serif-monospace" />

            </LinearLayout>
        </FrameLayout>

        <!-- Píldora de Entrada (Principal) -->
        <LinearLayout
            android:id="@+id/pill_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/pill_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/assistant_logo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="@color/white" />

            <EditText
                android:id="@+id/status_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="DI algo o escribe aquí..."
                android:textColor="@color/white"
                android:textColorHint="#88FFFFFF"
                android:textSize="14sp"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences"
                android:maxLines="2" />

            <com.eddam.heysary.VoiceWaveView
                android:id="@+id/voice_wave"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/mic_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/pill_background"
                android:backgroundTint="@color/cyberpunk_red"
                android:padding="12dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/white" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
