<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyberpunk_black">

    <!-- Header: Reloj y Fecha -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/clock_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20:45:12"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="serif-monospace" />

        <TextView
            android:id="@+id/date_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MARTES, 21 ABRIL"
            android:textColor="@color/cyberpunk_red"
            android:letterSpacing="0.2"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Engranaje Exterior (Cinetico) -->
    <ImageView
        android:id="@+id/outer_gear"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:src="@drawable/jarvis_gear"
        android:alpha="0.4"
        app:layout_constraintBottom_toBottomOf="@+id/jarvis_core"
        app:layout_constraintEnd_toEndOf="@+id/jarvis_core"
        app:layout_constraintStart_toStartOf="@+id/jarvis_core"
        app:layout_constraintTop_toTopOf="@+id/jarvis_core" />

    <!-- Engranaje Interior -->
    <ImageView
        android:id="@+id/inner_gear"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:src="@drawable/jarvis_gear"
        android:alpha="0.3"
        android:rotation="45"
        app:layout_constraintBottom_toBottomOf="@+id/jarvis_core"
        app:layout_constraintEnd_toEndOf="@+id/jarvis_core"
        app:layout_constraintStart_toStartOf="@+id/jarvis_core"
        app:layout_constraintTop_toTopOf="@+id/jarvis_core" />

    <!-- Resplandor Exterior del Núcleo (Glow Effect) -->
    <View
        android:id="@+id/core_glow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/avatar_glow_bg"
        android:alpha="0.6"
        app:layout_constraintBottom_toBottomOf="@+id/jarvis_core"
        app:layout_constraintEnd_toEndOf="@+id/jarvis_core"
        app:layout_constraintStart_toStartOf="@+id/jarvis_core"
        app:layout_constraintTop_toTopOf="@+id/jarvis_core" />

    <!-- Centro: El Núcleo de Sary (Protagonista con Fondo Pro) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/jarvis_core"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/dashboard_avatar"
        android:background="@drawable/avatar_glow_bg"
        app:strokeWidth="1dp"
        app:strokeColor="@color/cyberpunk_red"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_container" />

    <!-- Datos del Clima y Ubicación -->
    <LinearLayout
        android:id="@+id/weather_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_container">

        <TextView
            android:id="@+id/temp_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24°C"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/location_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIMA, PE"
            android:textColor="@color/cyberpunk_red"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Estado de Batería -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:gravity="end"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/weather_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/weather_container">

        <TextView
            android:id="@+id/battery_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="85%"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NIVEL ENERGÍA"
            android:textColor="@color/cyberpunk_red"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Botón de Activación Directa -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/manage_protocols_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="GESTIONAR PROTOCOLOS"
        android:textColor="@color/white"
        app:cornerRadius="4dp"
        app:strokeColor="@color/cyberpunk_red"
        app:strokeWidth="1dp"
        android:backgroundTint="@color/cyberpunk_black"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Barra de Navegación Inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/cyberpunk_black"
        app:itemIconTint="@color/cyberpunk_red"
        app:itemTextColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
